---
import { getRelativeLocaleUrl } from 'astro:i18n';
import LangSwitcher from '../components/LangSwitcher.astro';
import { t } from '../i18n/messages';

interface Props {
	locale: string | undefined;
}

const { locale } = Astro.props;
const copy = t(locale);
const htmlLang = locale === 'es' ? 'es' : 'en';
const homeHref = locale === 'es' ? getRelativeLocaleUrl('es', '') : getRelativeLocaleUrl('en', '');
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={copy.meta.description} />
		<title>{copy.meta.title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Source+Sans+3:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			:root {
				--bg: #f6f5f2;
				--fg: #14120f;
				--fg-muted: rgba(20, 18, 15, 0.55);
				--border: rgba(20, 18, 15, 0.08);
				--font-serif: 'Newsreader', 'Iowan Old Style', 'Palatino Linotype', ui-serif, serif;
				--font-sans: 'Source Sans 3', system-ui, sans-serif;
				--measure: 38rem;
				--space-page: clamp(1.5rem, 4vw, 3rem);
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100dvh;
				font-family: var(--font-sans);
				font-size: 1.0625rem;
				line-height: 1.55;
				color: var(--fg);
				background: var(--bg);
				-webkit-font-smoothing: antialiased;
			}
		</style>
	</head>
	<body>
		<div class="page">
			<header class="masthead">
				<a class="masthead__brand" href={homeHref}>{copy.brand}</a>
				<LangSwitcher locale={locale} />
			</header>

			<slot />
		</div>
	</body>
</html>

<style>
	.page {
		min-height: 100dvh;
		padding: var(--space-page);
		max-width: calc(var(--measure) + 2 * var(--space-page));
		margin: 0 auto;
		display: flex;
		flex-direction: column;
	}

	.masthead {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: clamp(2rem, 8vh, 4.5rem);
		border-bottom: 1px solid var(--border);
		margin-bottom: clamp(2rem, 8vh, 4rem);
	}

	.masthead__brand {
		font-family: var(--font-serif);
		font-size: 1.25rem;
		font-weight: 500;
		letter-spacing: -0.02em;
		color: inherit;
		text-decoration: none;
	}

	.masthead__brand:hover {
		opacity: 0.72;
	}
</style>
